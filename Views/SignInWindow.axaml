<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EventSeatManager.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1140" d:DesignHeight="720"
        x:Class="EventSeatManager.Views.SignInWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="EventSeatManager"
        Width="1140"
        Height="720"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        SystemDecorations="Full"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Border CornerRadius="20" Background="White" BoxShadow="0 0 20 5 #333366">
        <Grid ColumnDefinitions="Auto, *" Margin="20">
			<Grid Grid.Column="0" Width="600">
				<Border ClipToBounds="True" CornerRadius="20">
                    <Image Source="/Assets/LoginBackground.jpg" Stretch="UniformToFill" Margin="0,0,-500, 0">
                        <Image.Clip>
                            m 0 0 l 600 0 l -200 900 l -900 0 l 0 -600
                        </Image.Clip>
                    </Image>
                </Border>
                <Grid>
                    <Grid Grid.Row="0" ColumnDefinitions="*" Margin="35">
                        <TextBlock Grid.Column="0" TextWrapping="Wrap" Text="Добро пожаловать  в EventSeat!"
                                   FontSize="50" FontWeight="Bold" Foreground="rgba(255, 255, 255, 0.85)"
                                   VerticalAlignment="Top" Margin="0, 100"/>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Column="1" ShowGridLines="False" RowDefinitions="Auto, Auto, *, *">
                    <TextBlock Grid.Row="0" Text="Войти в аккаунт" FontSize="40" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0, 50"/>
                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0, 0, 0, 0">
						<TextBox Watermark="Введите email" FontSize="20" BorderBrush="Gray"
                                 BorderThickness="2" CornerRadius="12" Height="50" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0, 20, 0, 0">
                        <TextBox Watermark="Введите пароль" FontSize="20" BorderBrush="Gray"
                                 BorderThickness="2" CornerRadius="12" Height="50" VerticalContentAlignment="Center"/>
                    </StackPanel>
            </Grid>
           <!-- <ContentControl Content="{Binding CurrentView}"/> -->
        </Grid>
    </Border>
</Window>
