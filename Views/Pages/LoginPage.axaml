<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EventSeatManager.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1140" d:DesignHeight="720"
             x:Class="EventSeatManager.LoginPage"
             x:DataType="vm:LoginPageViewModel">

    <Design.DataContext>
       <vm:LoginPageViewModel />
    </Design.DataContext>

    <Border CornerRadius="0" Background="White">
        <Grid ColumnDefinitions="Auto, *" Margin="20">

            <!-- Левая декоративная часть -->
			<Grid Grid.Column="0" Width="650">
				<Border ClipToBounds="True" CornerRadius="20">
                    <Image Source="/Assets/LoginBackground.jpg" Stretch="UniformToFill" Margin="0,0,-500, 0">
                        <Image.Clip>
                            <PathGeometry>
                                m 0 0 l 650 0 l -250 900 l -900 0 l 0 -600	
                            </PathGeometry>
                        </Image.Clip>
                    </Image>
                </Border>
                <Grid RowDefinitions="Auto, *" Margin="35">
                    <StackPanel Grid.Row="0">
                        <Button Command="{Binding InLoginRegistrButtonCommand}" Content="Зарегистрироваться" FontSize="20" Foreground="rgba(255, 255, 255, 0.85)"
                                BorderBrush="White" BorderThickness="2" CornerRadius="12" HorizontalAlignment="Right"
                                Margin="0,-10,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1">
                        <TextBlock Grid.Row="0" TextWrapping="Wrap" Text="Добро пожаловать&#10;в EventSeat!"
                                   FontSize="50" FontWeight="Bold" Foreground="rgba(255, 255, 255, 0.85)"
                                   VerticalAlignment="Top" Margin="0, 170"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Правая функциональная часть -->
            <Grid Grid.Column="1" ShowGridLines="False" RowDefinitions="Auto, Auto, Auto, Auto, Auto" Margin="0, 100, 0, 0">
                <TextBlock Grid.Row="0" Text="Войти в аккаунт" FontSize="50" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0, 30" Background="Transparent"/>
                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0, 0, 0, 0">
                    <TextBox Text="{Binding LoginEmailInput}" Watermark="Введите email" FontSize="24" BorderBrush="Gray"
                             BorderThickness="2" CornerRadius="12" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0, 20, 0, 0">
                    <TextBox Text="{Binding LoginPasswordInput}" Watermark="Введите пароль" FontSize="24" BorderBrush="Gray"
                             BorderThickness="2" CornerRadius="12" VerticalContentAlignment="Center"
                             PasswordChar="*"/>
                </StackPanel>
                
                <StackPanel Grid.Row="3" Orientation="Vertical">
                    <Button Command="{Binding LoginButtonCommand}" Content="Войти" CornerRadius="12" BorderThickness="2"
                            HorizontalAlignment="Center" FontSize="30" Foreground="rgba(255,255,255, 0.85)" Width="400"
                            HorizontalContentAlignment="Center" Margin="0, 20, 0, 0" HotKey="Enter">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="Purple" Offset="0.1"/>
                                <GradientStop Color="rgba(36, 0, 97, 0.85)" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="4" Margin="0, 20, 0, 0" TextWrapping="Wrap"
                           Text="{Binding ErrorMessage}" Foreground="Red" FontSize="25"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
