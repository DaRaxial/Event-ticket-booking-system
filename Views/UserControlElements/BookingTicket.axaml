<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:EventSeatManager.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="EventSeatManager.BookingTicket"
             x:DataType="models:Seats">
    <Border>
		<StackPanel Orientation="Horizontal" Margin="0, 10">
			<TextBlock Text="{Binding Id, StringFormat='{}{0} место'}" Margin="10,0" FontSize="25" FontWeight="Medium"/>
			<TextBlock Text="{Binding Row, StringFormat='{}{0} ряд'}" Margin="0,0, 10, 0" FontSize="25" FontWeight="Medium"/>
			<TextBlock Text="— 500 рублей" Margin="0,0, 0, 0" FontSize="25" FontWeight="Medium"/>
        </StackPanel>
    </Border>
</UserControl>
