<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:EventSeatManager.Models"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="EventSeatManager.SeatButton"
			 x:DataType="models:Seats">
	<StackPanel>
		<Button CornerRadius="20" Width="35" Height="35" Content="{Binding Id}" FontWeight="Medium"
				HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="rgba(122, 22, 156, 1)"
				Margin="0, 0, 15, 10" Foreground="White">
		</Button>
	</StackPanel>
</UserControl>
